#
.DEFAULT_GOAL := vars

.PHONY: default init conf patch patch.revert build distclean distclean.modulesgen symlinks github github.check null conf.show

default: vars

init: init.base init.modules

conf: conf.base conf.modules

conf.show: conf.base.show conf.modules.show

patch: patch.base.apply  patch.mca.apply patch.opcua.apply patch.opcua.export.apply patch.feed-core.apply

# Keep this list the exact reverse of the patch: prerequisite list;
# stacked patches only unapply correctly in reverse apply order.
patch.revert: patch.feed-core.revert patch.opcua.export.revert patch.opcua.revert patch.mca.revert patch.base.revert

build: conf.base build.base conf.modules build.modules

build.gz: conf.gz.base build.base conf.gz.modules build.modules

distclean: distclean.base distclean.modules distclean.modulesgen

distclean.modulesgen:
	-rm -rf $(TOP)/configure/MODULESGEN.mk

symlinks: symlinks.modules

github: init patch vars conf build symlinks

github.check: init patch vars conf check.module-deps build symlinks

null:
	@echo ""
